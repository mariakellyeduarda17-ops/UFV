      "source": [
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import Conv2D, MaxPooling2D, Flatten, Dense, Dropout, Input\n",
        "\n",
        "# 2. Instantiate a Sequential model\n",
        "model = Sequential([\n",
        "    # Add an Input layer to explicitly define input shape\n",
        "    Input(shape=(32, 32, 3)),\n",
        "    # 3. Add a Conv2D layer\n",
        "    Conv2D(32, (3, 3), activation='relu'),\n",
        "    # 4. Add a MaxPooling2D layer\n",
        "    MaxPooling2D((2, 2)),\n",
        "    # 5. Add another Conv2D layer\n",
        "    Conv2D(64, (3, 3), activation='relu'),\n",
        "    # 6. Add another MaxPooling2D layer\n",
        "    MaxPooling2D((2, 2)),\n",
        "    # 7. Add a Flatten layer\n",
        "    Flatten(),\n",
        "    # 8. Add a Dense layer\n",
        "    Dense(128, activation='relu'),\n",
        "    # 9. Add a Dropout layer\n",
        "    Dropout(0.5),\n",
        "    # 10. Add a final Dense layer for output\n",
        "    Dense(10, activation='softmax') # 10 classes for CIFAR-10\n",
        "])\n",
        "\n",
        "# 11. Print the model summary\n",
        "model.summary()\n",
        "\n",
        "print(\"CNN model architecture defined successfully.\")"
